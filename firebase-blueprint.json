{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user profile information, balance, and role.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier for the user." },
        "displayName": { "type": "string", "description": "User's full name." },
        "email": { "type": "string", "format": "email", "description": "User's email address." },
        "photoURL": { "type": "string", "description": "URL to user's profile picture." },
        "balance": { "type": "number", "description": "Current account balance in Naira." },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "User's role in the platform." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp." },
        "lastLogin": { "type": "string", "format": "date-time", "description": "Last login timestamp." }
      },
      "required": ["uid", "email", "balance", "role"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Records financial activities like deposits, withdrawals, and interest payouts.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["deposit", "withdrawal", "investment_buy", "investment_sell", "interest_payout"] },
        "description": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "success", "failed"] }
      },
      "required": ["userId", "amount", "type", "timestamp", "status"]
    },
    "SavingsGoal": {
      "title": "Savings Goal",
      "description": "User-defined savings targets.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "targetAmount": { "type": "number" },
        "currentAmount": { "type": "number" },
        "deadline": { "type": "string", "format": "date" },
        "category": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "targetAmount", "currentAmount", "deadline"]
    },
    "Investment": {
      "title": "Investment Holding",
      "description": "Tracks a user's specific asset holdings.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "assetId": { "type": "string" },
        "assetName": { "type": "string" },
        "amount": { "type": "number" },
        "purchasePrice": { "type": "number" },
        "currentPrice": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "assetId", "amount", "purchasePrice"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Individual user profiles."
    },
    "/transactions": {
      "schema": "Transaction",
      "description": "Global transaction log (filtered by userId in app)."
    },
    "/savings_goals": {
      "schema": "SavingsGoal",
      "description": "User savings goals."
    },
    "/investments": {
      "schema": "Investment",
      "description": "User investment holdings."
    }
  }
}
